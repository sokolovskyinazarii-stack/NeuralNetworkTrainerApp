<Window
    x:Class="NeuralNetworkTrainerApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NeuralNetworkTrainerApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Neural Network Trainer"
    mc:Ignorable="d">

    <Grid
        Background="{StaticResource AppPageBrush}"
        RequestedTheme="Light">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="28,22,28,18"
            Background="{StaticResource AppSurfaceBrush}"
            BorderBrush="{StaticResource AppStrokeBrush}"
            BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="48"
                    Height="48"
                    Background="{StaticResource AppAccentBrush}"
                    CornerRadius="10">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="NN" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="3">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource AppTextBrush}"
                        Text="Neural Trainer" />
                    <TextBlock
                        Foreground="{StaticResource AppMutedTextBrush}"
                        Text="Навчання та перевірка моделі розпізнавання цифр"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border
                    Grid.Column="2"
                    MinWidth="150"
                    Padding="14,10"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="{StaticResource AppAccentSoftBrush}"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource MetricLabelTextStyle}"
                            Text="Статус" />
                        <TextBlock
                            x:Name="StatusText"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppAccentBrush}"
                            Text="Готово" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid
                x:Name="ContentGrid"
                Padding="28"
                ColumnSpacing="24"
                RowSpacing="24"
                SizeChanged="ContentGrid_SizeChanged">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SettingsColumn" Width="360" />
                    <ColumnDefinition x:Name="WorkspaceColumn" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="SettingsPanel"
                    Grid.Row="0"
                    Grid.Column="0"
                    Padding="20"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="4">
                            <TextBlock
                                Style="{StaticResource SectionTitleTextStyle}"
                                Text="Конфігурація" />
                            <TextBlock
                                Style="{StaticResource CaptionTextStyle}"
                                Text="Налаштування експерименту перед запуском." />
                        </StackPanel>

                        <StackPanel Spacing="12">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AppTextBrush}"
                                    Text="Навчальна вибірка" />
                                <NumberBox
                                    x:Name="TrainSizeBox"
                                    LargeChange="1000"
                                    Maximum="100000"
                                    Minimum="100"
                                    PlaceholderText="5000"
                                    SmallChange="500"
                                    SpinButtonPlacementMode="Compact"
                                    Value="5000" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AppTextBrush}"
                                    Text="Тестова вибірка" />
                                <NumberBox
                                    x:Name="TestSizeBox"
                                    LargeChange="1000"
                                    Maximum="10000"
                                    Minimum="100"
                                    PlaceholderText="2000"
                                    SmallChange="500"
                                    SpinButtonPlacementMode="Compact"
                                    Value="2000" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AppTextBrush}"
                                    Text="Нейронів у шарі" />
                                <NumberBox
                                    x:Name="HiddenBox"
                                    LargeChange="32"
                                    Maximum="512"
                                    Minimum="16"
                                    PlaceholderText="128"
                                    SmallChange="16"
                                    SpinButtonPlacementMode="Compact"
                                    Value="128" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AppTextBrush}"
                                    Text="Епохи" />
                                <NumberBox
                                    x:Name="EpochsBox"
                                    LargeChange="5"
                                    Maximum="50"
                                    Minimum="1"
                                    PlaceholderText="5"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Compact"
                                    Value="5" />
                            </StackPanel>

                            <ToggleSwitch
                                x:Name="SecondLayerSwitch"
                                Header="Другий прихований шар"
                                OffContent="Вимкнено"
                                OnContent="Dense(64, ReLU)" />
                        </StackPanel>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Grid.Column="0"
                                Click="SmallPreset_Click"
                                Content="Базовий"
                                Style="{StaticResource SecondaryActionButtonStyle}" />
                            <Button
                                Grid.Column="1"
                                Click="LargePreset_Click"
                                Content="Точний"
                                Style="{StaticResource SecondaryActionButtonStyle}" />
                        </Grid>

                        <Button
                            x:Name="TrainButton"
                            Click="TrainButton_Click"
                            Content="Почати навчання"
                            Style="{StaticResource PrimaryActionButtonStyle}" />
                    </StackPanel>
                </Border>

                <Grid
                    x:Name="WorkspacePanel"
                    Grid.Row="0"
                    Grid.Column="1"
                    RowSpacing="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        x:Name="MetricsGrid"
                        ColumnSpacing="14"
                        RowSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="MetricColumnOne" Width="*" />
                            <ColumnDefinition x:Name="MetricColumnTwo" Width="*" />
                            <ColumnDefinition x:Name="MetricColumnThree" Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            x:Name="AccuracyCard"
                            Padding="18"
                            Background="{StaticResource AppSurfaceBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Style="{StaticResource MetricLabelTextStyle}"
                                    Text="Точність" />
                                <TextBlock
                                    x:Name="AccuracyText"
                                    Style="{StaticResource MetricValueTextStyle}"
                                    Text="--" />
                            </StackPanel>
                        </Border>

                        <Border
                            x:Name="CorrectCard"
                            Grid.Column="1"
                            Padding="18"
                            Background="{StaticResource AppSurfaceBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Style="{StaticResource MetricLabelTextStyle}"
                                    Text="Правильно" />
                                <TextBlock
                                    x:Name="CorrectText"
                                    Style="{StaticResource MetricValueTextStyle}"
                                    Text="--" />
                            </StackPanel>
                        </Border>

                        <Border
                            x:Name="ArchitectureCard"
                            Grid.Column="2"
                            Padding="18"
                            Background="{StaticResource AppSurfaceBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Style="{StaticResource MetricLabelTextStyle}"
                                    Text="Архітектура" />
                                <TextBlock
                                    x:Name="ArchitectureText"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AppTextBrush}"
                                    Text="784 -> 128 -> 10"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid
                        x:Name="DetailsGrid"
                        Grid.Row="1"
                        ColumnSpacing="18"
                        RowSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="HistoryColumn" Width="*" />
                            <ColumnDefinition x:Name="PredictionsColumn" Width="1.1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="18"
                            Background="{StaticResource AppSurfaceBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock
                                            Style="{StaticResource SectionTitleTextStyle}"
                                            Text="Історія епох" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Loss, train і test після кожної епохи." />
                                    </StackPanel>
                                    <ProgressRing
                                        x:Name="TrainingProgress"
                                        Grid.Column="1"
                                        Width="32"
                                        Height="32"
                                        IsActive="False" />
                                </Grid>

                                <ProgressBar
                                    x:Name="AccuracyBar"
                                    Grid.Row="1"
                                    Maximum="100"
                                    Minimum="0"
                                    Value="0" />

                                <ListView
                                    x:Name="HistoryList"
                                    Grid.Row="2"
                                    MaxHeight="260"
                                    BorderThickness="0"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid
                                                Padding="0,8"
                                                ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="52" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding EpochText}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding AccuracyText}" />
                                                    <TextBlock
                                                        Style="{StaticResource CaptionTextStyle}"
                                                        Text="{Binding LossText}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Right"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource AppSuccessBrush}"
                                                    Text="{Binding TestText}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <Border
                            x:Name="PredictionsCard"
                            Grid.Column="1"
                            Padding="18"
                            Background="{StaticResource AppSurfaceBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Spacing="3">
                                    <TextBlock
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="Прогнози" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Перші тестові приклади після навчання." />
                                </StackPanel>

                                <ListView
                                    x:Name="PredictionsList"
                                    Grid.Row="1"
                                    MaxHeight="320"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid
                                                Padding="0,8"
                                                ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="42" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="96" />
                                                </Grid.ColumnDefinitions>
                                                <Border
                                                    Width="32"
                                                    Height="32"
                                                    Background="{StaticResource AppAccentSoftBrush}"
                                                    CornerRadius="8">
                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource AppAccentBrush}"
                                                        Text="{Binding IndexText}" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock
                                                        FontWeight="SemiBold"
                                                        Text="{Binding PredictionText}" />
                                                    <TextBlock
                                                        Style="{StaticResource CaptionTextStyle}"
                                                        Text="{Binding ConfidenceText}" />
                                                </StackPanel>
                                                <TextBlock
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Right"
                                                    FontWeight="SemiBold"
                                                    Foreground="{Binding ResultBrush}"
                                                    Text="{Binding ResultText}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid
                        x:Name="DiagnosticsGrid"
                        Grid.Row="2"
                        ColumnSpacing="18"
                        RowSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="MistakeColumn" Width="320" />
                            <ColumnDefinition x:Name="LogColumn" Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Padding="18"
                            Background="{StaticResource AppSurfaceBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="3">
                                    <TextBlock
                                        Style="{StaticResource SectionTitleTextStyle}"
                                        Text="Перша помилка" />
                                    <TextBlock
                                        x:Name="MistakeText"
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="З'явиться після запуску." />
                                </StackPanel>
                                <Border
                                    Width="224"
                                    Height="224"
                                    HorizontalAlignment="Left"
                                    Background="#F8FAFC"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Canvas
                                        x:Name="MistakeCanvas"
                                        Width="224"
                                        Height="224" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border
                            x:Name="LogCard"
                            Grid.Column="1"
                            Padding="18"
                            Background="{StaticResource AppSurfaceBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Style="{StaticResource SectionTitleTextStyle}"
                                    Text="Журнал" />
                                <TextBox
                                    x:Name="LogBox"
                                    Grid.Row="1"
                                    MinHeight="180"
                                    AcceptsReturn="True"
                                    FontFamily="Consolas"
                                    FontSize="12"
                                    IsReadOnly="True"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                                    TextWrapping="NoWrap"
                                    />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
